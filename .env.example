# ──────────────────────────────────────────────────────────────
# AVISA-WebFlotaElectricos — Variables de entorno para Vercel
# Copia estas variables en tu proyecto de Vercel:
#   Vercel Dashboard → tu proyecto → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# ── Base de datos (Supabase PostgreSQL) ──────────────────────
# Para Vercel serverless: usa el modo Transaction pooler (puerto 6543)
# Supabase Dashboard → Settings → Database → Connection string → Transaction mode
# Ejemplo: postgresql://postgres.uqkmjxdeeckavfteycmd:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
#
# Para desarrollo local puedes usar la conexión directa (puerto 5432):
# postgresql://postgres:PASSWORD@db.uqkmjxdeeckavfteycmd.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.uqkmjxdeeckavfteycmd:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Supabase (cliente JS) ─────────────────────────────────────
# Obtener en: Supabase → Settings → API
SUPABASE_URL=https://uqkmjxdeeckavfteycmd.supabase.co
SUPABASE_ANON_KEY=eyXXXXXXXXXXXX...
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXX...

# ── Sesiones (admin panel) ────────────────────────────────────
# Genera una clave aleatoria segura (mínimo 32 caracteres)
SESSION_SECRET=cambia-esto-por-una-clave-secreta-segura-32-chars

# ── Entorno ───────────────────────────────────────────────────
NODE_ENV=production

# ── URL pública del sitio ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://electricos.grupoavisa.com
